{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HA Camera Viewer",
  "version": "2.0.0",
  "identifier": "com.ha.cameraviewer",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "compression": "lzma"
      }
    }
  }
}
